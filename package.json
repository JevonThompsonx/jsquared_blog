{
  "name": "jsquaredadventures",
  "version": "0.3.1",
  "private": true,
  "description": "J² Adventures travel blog with Everything Claude Code repo tooling",
  "author": "Jevon Thompson",
  "license": "MIT",
  "homepage": "https://jsquaredadventures.com",
  "keywords": [
    "travel-blog",
    "nextjs",
    "opencode",
    "claude-code",
    "ai",
    "automation"
  ],
  "workspaces": [
    "./web"
  ],
  "scripts": {
    "dev": "bun run --cwd web dev",
    "build": "bun run --cwd web build",
    "lint": "bun run lint:web && bun run lint:ecc",
    "test": "bun run test:web && bun run test:ecc",
    "dev:web": "bun run --cwd web dev",
    "build:web": "bun run --cwd web build",
    "lint:web": "bun run --cwd web lint",
    "test:web": "bun run --cwd web test",
    "lint:ecc": "eslint . && markdownlint '**/*.md' --ignore node_modules --ignore web/node_modules",
    "test:ecc": "node scripts/ci/check-unicode-safety.js && node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-hooks.js && node scripts/ci/validate-install-manifests.js && node scripts/ci/validate-no-personal-paths.js && npm run catalog:check && node tests/run-all.js",
    "catalog:check": "node scripts/ci/catalog.js --text",
    "catalog:sync": "node scripts/ci/catalog.js --write --text",
    "harness:audit": "node scripts/harness-audit.js",
    "claw": "node scripts/claw.js",
    "orchestrate:status": "node scripts/orchestration-status.js",
    "orchestrate:worker": "bash scripts/orchestrate-codex-worker.sh",
    "orchestrate:tmux": "node scripts/orchestrate-worktrees.js",
    "coverage": "c8 --all --include=\"scripts/**/*.js\" --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --reporter=text --reporter=lcov node tests/run-all.js"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "ajv": "^8.18.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "c8": "^11.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.48.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.9.2+sha512.1fc009bc09d13cfd0e19efa44cbfc2b9cf6ca61482725eb35bbc5e257e093ebf4130db6dfe15d604ff4b79efd8e1e8e99b25fa7d0a6197c9f9826358d4d65c3c"
}
