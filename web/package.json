{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "tsx ./scripts/build.ts",
    "build:analyze": "ANALYZE=true pnpm run build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx ./scripts/migrate.ts",
    "db:import:supabase": "tsx ./scripts/import-supabase.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "e2e:capture-admin-state": "node --import tsx/esm ./scripts/capture-admin-storage-state.ts",
    "e2e:capture-public-state": "tsx ./scripts/capture-public-storage-state.ts",
    "seed:e2e": "tsx ./scripts/seed-e2e-fixtures.ts",
    "seed:wishlist": "tsx ./scripts/seed-wishlist.ts"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-select": "2.3.1",
    "@sentry/nextjs": "10.59.0",
    "@supabase/supabase-js": "2.108.2",
    "@tiptap/core": "3.27.1",
    "@tiptap/extension-image": "3.27.1",
    "@tiptap/extension-link": "3.27.1",
    "@tiptap/extension-placeholder": "3.27.1",
    "@tiptap/react": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "browser-image-compression": "2.0.2",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "emoji-picker-react": "^4.18.0",
    "maplibre-gl": "5.24.0",
    "next": "16.2.9",
    "next-auth": "4.24.14",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-map-gl": "^8.1.0",
    "sanitize-html": "2.17.5",
    "server-only": "^0.0.1",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vite": "7.1.12",
    "vitest": "4.1.9"
  }
}
