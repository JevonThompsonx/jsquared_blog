# Web app environment template.
# Copy to `web/.env.local` for local development.

# ── Database ──────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Supabase (public auth) ────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Admin Auth (GitHub OAuth) ─────────────────────────
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_ADMIN_GITHUB_IDS=
AUTH_SECRET=

# ── Cloudinary (images) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=

# ── Optional: Map tiles ───────────────────────────────
NEXT_PUBLIC_STADIA_MAPS_API_KEY=

# ── Optional: Email (Resend) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
COMMENT_NOTIFICATION_TO_EMAIL=
RESEND_NEWSLETTER_SEGMENT_ID=

# ── Optional: Rate limiting (Upstash Redis) ───────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional: Cron ────────────────────────────────────
CRON_SECRET=

# ── Optional: Observability (Sentry) ──────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Optional: Playwright / E2E helpers ────────────────
E2E_BASE_URL=
E2E_ALLOW_SUPABASE_SEED=
E2E_APPROVED_SUPABASE_URLS=
E2E_PUBLIC_EMAIL=
E2E_PUBLIC_PASSWORD=
E2E_PUBLIC_POST_SLUG=
E2E_PUBLIC_FIXTURE_GENERATED_AT=
E2E_PUBLIC_ENV_METADATA=
E2E_PUBLIC_STORAGE_STATE=
E2E_ALLOW_REMOTE_PUBLIC_CAPTURE=
E2E_ADMIN_STORAGE_STATE=
E2E_ADMIN_POST_ID=
E2E_ALLOW_REMOTE_ADMIN_MUTATIONS=
E2E_CAPTURE_HEADLESS=
E2E_CAPTURE_LAUNCH_TIMEOUT_MS=
E2E_CAPTURE_SIGNIN_TIMEOUT_MS=
